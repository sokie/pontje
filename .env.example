# Copy to .env next to docker-compose.yml on the NAS; compose substitutes these.
#
# In production (an https domain) these are MANDATORY: the server fails fast at
# boot (PLAN.md §23) if PONTJE_SESSION_SECRET / PONTJE_SECRET_KEY / the Google
# client id+secret / PONTJE_ALLOWED_EMAILS are missing or left at dev defaults,
# or if PONTJE_DEV_FAKE_LOGIN is on.

# Your public domain. docker-compose turns this into the variable the app
# ACTUALLY reads — PONTJE_PUBLIC_BASE_URL (= https://$PONTJE_DOMAIN) — and Caddy
# uses the bare domain for TLS. On hosts WITHOUT docker-compose (e.g. Railway)
# there is no substitution: set PONTJE_PUBLIC_BASE_URL directly to your full
# https URL instead. If it's unset/wrong, Google sign-in redirects to localhost
# and cookies aren't Secure.
PONTJE_DOMAIN=pontje.example.com
# Non-compose deploys set this directly (leave PONTJE_DOMAIN above unused):
#PONTJE_PUBLIC_BASE_URL=https://pontje.example.com

# Google Cloud Console → OAuth client (Web application), PLAN.md §7.2.
PONTJE_GOOGLE_CLIENT_ID=
PONTJE_GOOGLE_CLIENT_SECRET=

# Comma-separated Google account emails allowed to sign in.
PONTJE_ALLOWED_EMAILS=you@gmail.com

# Signs the transient OAuth state cookie:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
PONTJE_SESSION_SECRET=

# Fernet key encrypting secret snippets at rest:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PONTJE_SECRET_KEY=

# ---- AI / LLM (optional, OFF by default) -----------------------------------
# Link summaries + long-tail categorization via any OpenAI-compatible
# chat endpoint (Ollama on the NAS, LM Studio, OpenRouter, …).
# HARD kill-switch — set to 1 to disable ALL AI features regardless of config:
PONTJE_AI_DISABLED=0
# AI only activates when BOTH of these are set:
#PONTJE_LLM_BASE_URL=http://ollama:11434/v1
#PONTJE_LLM_MODEL=qwen3:1.7b
#PONTJE_LLM_API_KEY=          # only for cloud endpoints
